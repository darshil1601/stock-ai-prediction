# Database (get from Supabase dashboard)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-or-service-key

# Redis (Upstash free tier)
UPSTASH_REDIS_REST_URL=https://your-cluster.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token

# APIs (sign up free tiers)
TWELVE_DATA_API_KEY=your-key
NEWSAPI_KEY=your-key  # optional if using GDELT only

# Features (set to 1 to enable)

ENABLE_AUTO_RETRAIN=1
RETRAIN_ON_EVENTS=1
STARTUP_BACKGROUND_JOBS=1
NEWS_INGEST_INTERVAL_MINUTES=5  # production: 5-15min to save costs

# Dev
ALLOWED_ORIGINS=http://localhost:5173,https://your-frontend-domain.com

# Server
PORT=8000

