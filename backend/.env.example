# ── Supabase ──────────────────────────────────────────
SUPABASE_URL=your-url-here
# Use the SERVICE ROLE key (from Dashboard → Settings → API → service_role)
# Note: Keep this secret and do not share it.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Upstash Redis ──────────────────────────────────────
UPSTASH_REDIS_REST_URL=your-url-here
UPSTASH_REDIS_REST_TOKEN=your-token-here

# ── Twelve Data ────────────────────────────────────────
TWELVE_DATA_KEY=your-api-key-here

# ── NewsAPI ───────────────────────────────────────────
NEWSAPI_KEY=your-api-key-here

# ── Features and Background Jobs ───────────────────────
# Master switch for automatic model training (1=on, 0=off)
ENABLE_AUTO_RETRAIN=1
# Allow retrain triggers from manual endpoints or specific events
RETRAIN_ON_EVENTS=1
# Run jobs like reconciliation and news ingestion on startup
STARTUP_BACKGROUND_JOBS=1
# Frequency of news fetching in minutes (1 to 60)
NEWS_INGEST_INTERVAL_MINUTES=5

# ── App Config ─────────────────────────────────────────
# Comma-separated list of allowed origins (no spaces)
ALLOWED_ORIGINS=your-origins-here
# environment: development or production
ENVIRONMENT=production
# Port to run the server on (default: 8000 for local, 7860 for Hugging Face)
# PORT=8000
